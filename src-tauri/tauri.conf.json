{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SakiDB",
  "version": "1.0.0",
  "identifier": "com.nevindra.sakidb",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nevindra/sakidb/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFEMDhCODlBQUM0MkFDREQKUldUZHJFS3NtcmdJSFN5RzNsWDFZMG9HQmxvU1YvZW1HeXlDZ2ZxOURhQ3JIQi9RcFVyT0FVRnYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A lightning-fast PostgreSQL client",
    "longDescription": "SakiDB is a lightweight, native desktop PostgreSQL client built for speed. Features include a full SQL editor with autocomplete, virtual-scrolled data grid with inline editing, schema explorer, ERD viewer, query history, CSV/SQL export, and encrypted credential storage.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 165, "y": 185 },
        "applicationFolderPosition": { "x": 495, "y": 185 }
      }
    }
  }
}
